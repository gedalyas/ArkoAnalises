# Supabase — pooler (Transaction Mode, porta 6543)
# Usado em RUNTIME pela API (conexões curtas, compatível com serverless)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — conexão direta (porta 5432)
# Usado SOMENTE pelo Prisma nas migrations (precisa de conexão persistente)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.db.supabase.co:5432/postgres"

PORT=3333
