# Supabase — pooler Transaction Mode (porta 6543)
# Usado em RUNTIME pela API
DATABASE_URL="postgresql://postgres.lwetcscbbzgcedbvhbzy:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — pooler Session Mode (porta 5432)
# Usado SOMENTE pelo Prisma nas migrations
DIRECT_URL="postgresql://postgres.lwetcscbbzgcedbvhbzy:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

PORT=3333

# CORS — origem(ns) do frontend autorizada(s), separadas por vírgula.
# Vazio = libera qualquer origem (ok p/ app público sem login). Em produção,
# aponte para a URL da Vercel, ex: https://arko-analises.vercel.app
WEB_ORIGIN=""

# Google Gemini — gerar em https://aistudio.google.com (Get API key)
# Usada na categorização e na geração do diagnóstico
GEMINI_API_KEY="AIza...sua-chave-aqui"

# Modelo Gemini (opcional). Default: gemini-2.5-flash (melhor categorização; exige billing).
# Use gemini-2.5-flash-lite se precisar ficar no free tier (menos preciso).
GEMINI_MODEL="gemini-2.5-flash"
